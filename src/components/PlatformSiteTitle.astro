---
import { getCollection } from 'astro:content';
import { logos } from 'virtual:starlight/user-images';
import config from 'virtual:starlight/user-config';
import {
  getPlatformFromSlug,
  getTopicFromSlug,
  normalizeDocSlug,
  platformOptions,
  resolveDocHref,
} from '../platforms';

const { siteTitle, slug } = Astro.locals.starlightRoute;
const is404Route = slug === '404' || slug.endsWith('/404');
const docs = is404Route ? [] : await getCollection('docs');
const availableDocs = new Set(docs.map((entry) => normalizeDocSlug(entry.id)));

const currentPlatform = getPlatformFromSlug(slug);
const currentTopic = getTopicFromSlug(slug);

const switchOptions = platformOptions.map((option) => {
  const preferredSlug = option.id === 'github'
    ? normalizeDocSlug(currentTopic)
    : normalizeDocSlug(`${option.id}/${currentTopic}`);
  const hasEquivalent = option.id === 'github' || availableDocs.has(preferredSlug);

  return {
    id: option.id,
    label: option.label,
    currentHref: resolveDocHref(availableDocs, option.id, currentTopic),
    homeHref: resolveDocHref(availableDocs, option.id),
    hasEquivalent,
  };
});
---

<div class="platform-title" data-platform-title data-options={JSON.stringify(switchOptions)} data-platform={currentPlatform} data-topic={currentTopic}>
  <a href={resolveDocHref(availableDocs, currentPlatform)} class="site-title sl-flex" data-site-title-link>
    {
      config.logo && logos.dark && (
        <>
          <img
            class:list={{ 'light:sl-hidden print:hidden': !('src' in config.logo) }}
            alt={config.logo.alt}
            src={logos.dark.src}
            width={logos.dark.width}
            height={logos.dark.height}
          />
          {!('src' in config.logo) && (
            <img
              class="dark:sl-hidden print:block"
              alt={config.logo.alt}
              src={logos.light?.src}
              width={logos.light?.width}
              height={logos.light?.height}
            />
          )}
        </>
      )
    }
    <span class:list={{ 'sr-only': config.logo?.replacesTitle }} translate="no">
      {siteTitle}
    </span>
  </a>

  <label class="platform-switch-label">
    <span class="sr-only">Choose tutorial interface</span>
    <select class="platform-switch" aria-label="Choose tutorial interface" data-platform-switch>
      {
        switchOptions.map((option) => (
          <option value={option.id} selected={option.id === currentPlatform}>
            {option.label}
          </option>
        ))
      }
    </select>
  </label>
</div>

<script is:inline>
  (() => {
    const storageKey = 'how-to-git-platform';
    const root = document.querySelector('[data-platform-title]');

    if (!(root instanceof HTMLElement)) return;

    const options = JSON.parse(root.dataset.options || '[]');
    const currentPlatform = root.dataset.platform || 'github';
    const currentTopic = root.dataset.topic || '';
    const select = root.querySelector('[data-platform-switch]');
    const titleLink = root.querySelector('[data-site-title-link]');

    if (!(select instanceof HTMLSelectElement)) return;

    const setPlatform = (platformId) => {
      const selected = options.find((option) => option.id === platformId);

      if (!selected) return;

      select.value = selected.id;

      if (titleLink instanceof HTMLAnchorElement) {
        titleLink.href = selected.homeHref;
      }
    };

    const savedPlatform = localStorage.getItem(storageKey);

    setPlatform(currentPlatform);

    if (currentPlatform === 'github' && currentTopic === '' && savedPlatform && savedPlatform !== currentPlatform) {
      const savedOption = options.find((option) => option.id === savedPlatform);

      if (savedOption) {
        window.location.replace(savedOption.currentHref);
        return;
      }
    }

    select.addEventListener('change', (event) => {
      const nextPlatform = event.currentTarget instanceof HTMLSelectElement ? event.currentTarget.value : '';
      const selected = options.find((option) => option.id === nextPlatform);

      if (!selected) return;

      localStorage.setItem(storageKey, selected.id);
      setPlatform(selected.id);
      window.location.assign(selected.currentHref);
    });
  })();
</script>

<style>
  @layer starlight.core {
    .platform-title {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      min-width: 0;
    }

    .site-title {
      align-items: center;
      gap: var(--sl-nav-gap);
      font-size: var(--sl-text-h4);
      font-weight: 600;
      color: var(--sl-color-text-accent);
      text-decoration: none;
      white-space: nowrap;
      min-width: 0;
    }

    .site-title span {
      overflow: hidden;
    }

    .site-title img {
      height: calc(var(--sl-nav-height) - 2 * var(--sl-nav-pad-y));
      width: auto;
      max-width: 100%;
      object-fit: contain;
      object-position: 0 50%;
    }

    .platform-switch-label {
      display: inline-flex;
      align-items: center;
      min-width: 0;
    }

    .platform-switch {
      appearance: none;
      border: 1px solid var(--sl-color-gray-5);
      border-radius: 999px;
      background: var(--sl-color-bg-nav);
      color: var(--sl-color-white);
      font: inherit;
      font-size: var(--sl-text-sm);
      line-height: 1.2;
      padding: 0.45rem 2rem 0.45rem 0.85rem;
      background-image:
        linear-gradient(45deg, transparent 50%, currentColor 50%),
        linear-gradient(135deg, currentColor 50%, transparent 50%);
      background-position:
        calc(100% - 1rem) calc(50% - 0.12rem),
        calc(100% - 0.7rem) calc(50% - 0.12rem);
      background-size: 0.35rem 0.35rem, 0.35rem 0.35rem;
      background-repeat: no-repeat;
      max-width: 11rem;
    }

    .platform-switch:hover,
    .platform-switch:focus-visible {
      border-color: var(--sl-color-text-accent);
      outline: none;
    }

    @media (max-width: 40rem) {
      .platform-title {
        gap: 0.5rem;
      }

      .platform-switch {
        max-width: 8.5rem;
        font-size: var(--sl-text-xs);
        padding-inline: 0.7rem 1.7rem;
      }
    }
  }
</style>