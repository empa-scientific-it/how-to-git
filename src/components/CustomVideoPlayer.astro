---
export interface Props {
    path: string;
}

const { path } = Astro.props;
---

<div class="video-container">
  <video width="400" height="225" controls>
    <source src={path} type="video/mp4" />
    Your browser does not support the video tag.
  </video>
</div>
<style>
  .video-container {
    margin: 1rem 0;
  }

  video {
    width: 100%;
    max-width: 800px;
    height: auto;
    border: 1px solid #ddd;
    border-radius: 4px;
  }
</style>

